  m_Script: {fileID: 11500000, guid: 77a57e97cf781cb46ab423fddaa0dae7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LLMConnectorWinOrLoseSentence
  _config:
  - {fileID: 2076484191}
  _inputField: {fileID: 0}
  _useSecuritySteps: 0
  _useHistoricalInContext: 1
  _useHistoricalInSteps: 0
  _prompt: "Analiza el siguiente caso y dicta un texto con la sentencia:\n\nResumen
    del caso: ~\n\nPruebas presentadas por !:\n@\n\nPruebas presentadas por \xA1:\n$\n\nDemanda
    de !:\n#\n\n\nGenera la sentencia del tribunal OBJETIVAMENTE comprobando que
    LA DEMANDA SE CORRESPONDE A LAS PRUEBAS PRESENTADAS. Si no se corresponde, invalidar
    las pruebas.\nAdem\xE1s valorar ambas pruebas y contrastarlas con el resumen
    del caso"
--- !u!114 &984039541
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
