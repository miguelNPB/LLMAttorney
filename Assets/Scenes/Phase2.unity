--- !u!114 &610842254
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 610842252}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f8502b51f8609944cac39c8657e6e55d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ConfigLLMInfo
  _apiType: 0
  context: "CONTEXTO \u2014 GENERACI\xD3N DE PRESUPUESTOS\r\n\r\nEres una herramienta
    que genera presupuestos para documentos necesarios en la preparaci\xF3n de un
    caso civil en Espa\xF1a.\r\n\r\nDebes generar informaci\xF3n sobre el coste de
    distintos tipos de documentos, que pueden ser:\r\n\r\n* informe pericial\r\n*
    informe general\r\n* testimonio\r\n* factura o recibo\r\n\r\nTu objetivo es indicar
    cu\xE1nto cuesta obtener estos documentos dentro de un caso civil, utilizando
    valores realistas del mercado en Espa\xF1a.\r\n\r\nTodas las respuestas deben
    centrarse en estos documentos y en su coste dentro del proceso legal.\r\n"
  safeguard: "SAFEGUARD \u2014 COSTE DEL DOCUMENTO (VERSI\xD3N ACTUALIZADA)\r\n\r\nDebes
    generar el campo: \"CosteDocumento\" (int)\r\n\r\n---\r\n\r\nREGLAS\r\n\r\n*
    El valor debe ser un n\xFAmero entero\r\n* Debe representar el coste de obtener
    el documento en Espa\xF1a\r\n* Debe basarse en los precios disponibles en el
    RAG\r\n\r\n---\r\n\r\nRESTRICCIONES\r\n\r\n* No inventar precios sin referencia\r\n*
    No usar valores aleatorios\r\n* No usar precios fuera de contexto\r\n* Ajustar
    el valor a rangos realistas seg\xFAn el tipo de documento\r\n\r\n---\r\n\r\nEN
    CASO DE DUDA\r\n\r\n* usar el valor m\xE1s cercano presente en el RAG\r\n"
  safeguardSteps: 
  historicalConversation: "HIST\xD3RICO \u2014 CONSISTENCIA DE PRESUPUESTOS (VERSI\xD3N
    ACTUALIZADA)\r\n\r\nDispones de un hist\xF3rico de respuestas previas.\r\n\r\n---\r\n\r\nREGLAS\r\n\r\n*
    Usa los presupuestos ya generados como referencia\r\n\r\n* Mant\xE9n coherencia
    entre respuestas similares\r\n\r\n* Si se repite el mismo tipo de documento:\r\n\r\n 
    * y ya se ha generado previamente \u2192 \"CosteDocumento\" = 0\r\n  * en otros
    casos \u2192 usa un coste igual o muy similar\r\n\r\n* Si es un documento distinto
    \u2192 ajusta el coste de forma coherente respecto a los anteriores\r\n\r\n---\r\n\r\nIMPORTANTE\r\n\r\n*
    No generar valores inconsistentes con respuestas previas\r\n* Mantener una l\xF3gica
    de precios estable\r\n* Evitar variaciones bruscas sin motivo\r\n"
  _stepChecks: []
  _temperature: 0
  _ragUse: 1
  _ragFile: 1
