  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Te encuentras en la primera fase del simulador. Durante esta iran llegando
    clientes los cuales te explicaran su situacion y el objetivo de su visita.\n\nTu
    objetivo ser\xE1 decidir si tomar su caso o no. Para ello deber\xE1s darles informaci\xF3n
    sobre el procedimiento mediante la creaci\xF3n de un presupuesto de los posibles
    gastos que tendran junto a tus honorarios. \n\nUna vez ambas partes esteis de
    acuerdo cerrareis el trato y podras avanzar de fase"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: a3e3feeea8d090346861eb7090dca316, type: 2}
  m_sharedMaterial: {fileID: -42240559382742459, guid: a3e3feeea8d090346861eb7090dca316, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
