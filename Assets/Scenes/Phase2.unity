  m_EditorClassIdentifier: Assembly-CSharp::ConfigLLMInfo
  _apiType: 0
  context: 
  safeguard: 
  safeguardSteps: 
  historicalConversation: 
  _stepChecks:
  - "Clasifica el documento seg\xFAn su tipo y modifica unicamente el campo tipoDocumento,
    poniendo unicamente un numero.\n\nReglas de clasificaci\xF3n:\n\nSi es un informe
    pericial: 1\nSi es un informe: 2\nSi es una declaraci\xF3n de un testigo: 3\nSi
    es un recibo o factura: 4"
  - "Modifica el campo contenidoDocumento:\nDebes eliminar completamente cualquier
    fragmento entre corchetes [...].\nDebes reemplazar esos fragmentos con informaci\xF3n
    inventada coherente y veros\xEDmil, manteniendo el contexto jur\xEDdico del documento.\nNo
    puedes dejar corchetes ni marcas de plantilla en la salida final.\nNo expliques
    los cambios.\nMant\xE9n el estilo de una declaraci\xF3n formal en derecho procesal
    civil en Espa\xF1a.\nSi falta informaci\xF3n, compl\xE9tala de forma razonable
    y consistente con el resto del texto"
  _temperature: 0
  _ragUse: 1
  _ragFile: 0
