--- !u!114 &1342102162
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1342102160}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f8502b51f8609944cac39c8657e6e55d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ConfigLLMInfo
  _apiType: 1
  context: "Redacta un informe general sobre lo que se ha pedido:\r\n\r\nEl tono
    debe ser claro, profesional y accesible.\r\n\r\nIncluir exactamente estas secciones
    como encabezados:\r\n    - T\xEDtulo\r\n    - Introducci\xF3n\r\n    - Desarrollo
    organizado en secciones\r\n    - An\xE1lisis de la situaci\xF3n actual\r\n   
    - Datos relevantes (puedes inventar ejemplos plausibles si no se proporcionan)\r\n   
    - Conclusiones\r\n    - Recomendaciones (si aplica)\r\n"
  safeguard: "DIRECTIVA \u2014 VALIDACI\xD3N INFORME GENERAL\r\n\r\nEval\xFAa el
    documento sin modificarlo.\r\n\r\nDevuelve:\r\n\"DocumentoCoherente\" (bool)\r\n\r\n---\r\n\r\nCRITERIOS\r\n\r\nTRUE
    solo si:\r\n\r\n* Es un informe estructurado (no necesariamente pericial)\r\n*
    Tiene estructura l\xF3gica (titulo + introducci\xF3n + desarrollo + analisis
    + datos relevantes + conclusiones)\r\n* El contenido es coherente\r\n* Est\xE1
    principalmente en espa\xF1ol\r\n\r\nFALSE si:\r\n\r\n* No tiene estructura de
    informe\r\n* Es incoherente o incomprensible\r\n* Mezcla clara de idiomas\r\n\r\n---\r\n\r\nREGLAS\r\n\r\n*
    No corregir\r\n* No modificar\r\n* No explicar\r\n* En caso de duda \u2192 TRUE\r\n\r\n\r\nSALIDA
    NO PERMITIDA:\r\nexplicaciones\r\nconfirmaciones\r\ncomentarios\r\netiquetas\r\n"
  safeguardSteps: 
  historicalConversation: "Analiza el hist\xF3rico de conversaci\xF3n que se te proporciona
    junto con la nueva pregunta.\r\n\r\nEl hist\xF3rico contiene pares de pregunta
    y respuesta anteriores.\r\n\r\nSi el documento es relevante a lo que se esta
    hablando, pon el campo EsValido a true, si no, a false\r\n"
  _stepChecks: []
  _temperature: 0.2
  _ragUse: 0
  _ragFile: 0
