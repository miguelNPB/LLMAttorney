PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 912615290}
    m_Modifications:
    - target: {fileID: 1229239301423809702, guid: fafe30ece380d6d4681a1e6a104fd641, type: 3}
