  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Pulsa la lupa para abrir una ventana en la cual podras hacer consultas
    sobre los distintos precios de los procedimientos, informes y equipo implicado
    en un proceso de derecho civil.\n\nEn caso de hacer consultas externas a este
    campo la herramienta no dar\xE1 ninguna informaci\xF3n. \n\nAprovecha la herramienta
    para preguntar por informes periciales, notarios,  tasas de abogados, tasas judiciales...
    No obstante cualquier informaci\xF3n personal que se tenga podra ser utilizada
    en lugar de la herramienta, sirviendo esta de complemento."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
